<script>
	(function() {
		const themeConfig = {{ themes | dump | safe }};
		const themeTarget = document.documentElement;
		const defaultThemeId = themeTarget.dataset.defaultTheme;
		const autoLightThemeId = themeTarget.dataset.autoLightTheme || defaultThemeId;
		const autoDarkThemeId = themeTarget.dataset.autoDarkTheme || defaultThemeId;
		const themeMap = themeConfig.reduce((map, theme) => {
			map[theme.id] = theme.classes;
			return map;
		}, {});
		const defaultMidtoneClass = {{ defaultThemeMidtoneClass | dump | safe }};
		const themeMidtoneMap = themeConfig.reduce((map, theme) => {
			const className = theme.midtoneClass || defaultMidtoneClass;
			map[theme.id] = className;
			return map;
		}, {});
		const allThemeClasses = Array.from(new Set(themeConfig.flatMap(theme => theme.classes)));
		const allMidtoneClasses = Array.from(new Set([
			defaultMidtoneClass,
			...Object.values(themeMidtoneMap)
		])).filter(Boolean);
		const storageKey = 'themePreference';
		const previewResetDelay = {{ previewResetDelay }};
		const previewHoverDelay = {{ siteThemeConfig.previewHoverDelay if siteThemeConfig.previewHoverDelay is defined else 120 }};
		const themeModeLabelTemplate = {{ ui.shared.theme.modeLabelTemplate | dump | safe }};
		const themeModeAutoLabel = {{ ui.shared.theme.auto | dump | safe }};
		const themeModeCustomLabel = {{ ui.shared.theme.custom | dump | safe }};
		const modePreferenceMap = {
			auto: 'auto',
			light: autoLightThemeId,
			dark: autoDarkThemeId
		};
		const modeSequence = ['auto', 'light', 'dark'];
		let activePreference = themeTarget.dataset.themePreference || 'auto';
		let previewButtons = [];
		let modeToggleButton;
		let previewResetTimeout;
		let previewHoverTimeout;
		let systemThemeQuery;

		function getSystemThemeId() {
			if (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches) {
				return themeMap[autoDarkThemeId] ? autoDarkThemeId : defaultThemeId;
			}
			return themeMap[autoLightThemeId] ? autoLightThemeId : defaultThemeId;
		}

		function resolveThemeId(preference) {
			if (preference === 'auto') {
				return getSystemThemeId();
			}
			return themeMap[preference] ? preference : defaultThemeId;
		}

		function getModeForPreference(preference) {
			if (preference === 'auto') return 'auto';
			if (preference === autoDarkThemeId) return 'dark';
			if (preference === autoLightThemeId) return 'light';
			return null;
		}

		function updateModeToggle(preference) {
			if (!modeToggleButton) return;
			const mode = getModeForPreference(preference);
			const label = mode === 'auto'
				? themeModeAutoLabel
				: mode
					? mode.charAt(0).toUpperCase() + mode.slice(1)
					: themeModeCustomLabel;
			const modeLabel = themeModeLabelTemplate.replace('{mode}', label);
			modeToggleButton.dataset.themeMode = mode || 'custom';
			modeToggleButton.setAttribute('aria-label', modeLabel);
			modeToggleButton.setAttribute('title', modeLabel);
			modeToggleButton.setAttribute('aria-pressed', String(Boolean(mode)));
			modeToggleButton.classList.toggle('o-60', !mode);
			if (mode) {
				modeToggleButton.setAttribute('data-active', '');
			} else {
				modeToggleButton.removeAttribute('data-active');
			}
			const labelNode = modeToggleButton.querySelector('.theme-mode-label');
			if (labelNode) labelNode.textContent = label;
		}

		function cycleThemeMode() {
			const currentMode = getModeForPreference(activePreference) || 'custom';
			const currentIndex = modeSequence.indexOf(currentMode);
			const nextMode = modeSequence[(currentIndex + 1) % modeSequence.length];
			applyTheme(nextMode === 'custom' ? 'auto' : modePreferenceMap[nextMode]);
		}

		function updateActivePreview(preference) {
			if (!previewButtons.length) return;
			previewButtons.forEach(button => {
				const isActive = button.dataset.themePreview === preference;
				if (isActive) {
					button.setAttribute('data-active', '');
				} else {
					button.removeAttribute('data-active');
				}
				button.classList.toggle('b--black-80', isActive);
				button.classList.toggle('o-60', !isActive);
				button.setAttribute('aria-pressed', String(isActive));
			});
		}

		function clearPreviewReset() {
			if (!previewResetTimeout) return;
			clearTimeout(previewResetTimeout);
			previewResetTimeout = undefined;
		}

		function clearPreviewHover() {
			if (!previewHoverTimeout) return;
			clearTimeout(previewHoverTimeout);
			previewHoverTimeout = undefined;
		}

		function schedulePreviewReset() {
			clearPreviewReset();
			previewResetTimeout = setTimeout(() => {
				applyTheme(activePreference, { persist: false, syncSelect: true, preview: true });
			}, previewResetDelay);
		}

		function applyTheme(preference, options = {}) {
			const { persist = true, syncSelect = true, preview = false } = options;
			const resolvedThemeId = resolveThemeId(preference);
			if (!themeMap[resolvedThemeId]) return;
			themeTarget.classList.remove(...allThemeClasses);
			themeTarget.classList.add(...themeMap[resolvedThemeId]);
			themeTarget.dataset.theme = resolvedThemeId;
			themeTarget.dataset.themePreference = preference;
			const midtoneClass = themeMidtoneMap[resolvedThemeId] || defaultMidtoneClass;
			if (allMidtoneClasses.length) {
				document.querySelectorAll('.theme-midtone').forEach(element => {
					element.classList.remove(...allMidtoneClasses);
					if (midtoneClass) element.classList.add(midtoneClass);
				});
			}
			if (!preview) {
				activePreference = preference;
				updateActivePreview(preference);
				updateModeToggle(preference);
				if (persist) {
					try {
						localStorage.setItem(storageKey, preference);
						localStorage.setItem('theme', resolvedThemeId);
					} catch (error) {
						/* localStorage may be unavailable; ignore persistence */
					}
				}
			}
			if (syncSelect) {
				document.querySelectorAll('[data-theme-select]').forEach(select => {
					if (select.value !== preference) select.value = preference;
				});
			}
		}

		function previewTheme(preference) {
			clearPreviewReset();
			applyTheme(preference, { persist: false, syncSelect: false, preview: true });
		}

		function schedulePreviewTheme(preference) {
			clearPreviewHover();
			previewHoverTimeout = setTimeout(() => {
				previewHoverTimeout = undefined;
				previewTheme(preference);
			}, previewHoverDelay);
		}

		function cancelPreview(event) {
			clearPreviewHover();
			if (event && event.relatedTarget && event.relatedTarget.closest && event.relatedTarget.closest('[data-theme-preview]')) {
				return;
			}
			schedulePreviewReset();
		}

		function initTheme() {
			let initial = themeTarget.dataset.themePreference || 'auto';
			try {
				const stored = localStorage.getItem(storageKey);
				if (stored === 'auto' || themeMap[stored]) {
					initial = stored;
				} else {
					const legacyStoredTheme = localStorage.getItem('theme');
					if (legacyStoredTheme === 'auto' || themeMap[legacyStoredTheme]) {
						initial = legacyStoredTheme;
					}
				}
			} catch (error) {
				/* ignore storage issues and fall back to default */
			}
			applyTheme(initial, { persist: false, syncSelect: false });
		}

		applyTheme(activePreference, { persist: false, syncSelect: false, preview: true });

		document.addEventListener('DOMContentLoaded', () => {
			initTheme();
			modeToggleButton = document.querySelector('[data-theme-mode-toggle]');
			if (modeToggleButton) {
				modeToggleButton.addEventListener('click', () => {
					clearPreviewReset();
					cycleThemeMode();
				});
			}
			const themeSelects = document.querySelectorAll('[data-theme-select]');
			themeSelects.forEach(select => {
				if (select.value !== 'auto' && !themeMap[select.value]) {
					select.value = themeTarget.dataset.themePreference;
				}
				select.addEventListener('change', event => {
					applyTheme(event.target.value);
				});
			});

			const supportsPointer = 'PointerEvent' in window;
			previewButtons = Array.from(document.querySelectorAll('[data-theme-preview]'));
			previewButtons.forEach(button => {
				const themeId = button.dataset.themePreview;
				const enterEvent = supportsPointer ? 'pointerenter' : 'mouseenter';
				const leaveEvent = supportsPointer ? 'pointerleave' : 'mouseleave';
				button.addEventListener(enterEvent, () => schedulePreviewTheme(themeId));
				button.addEventListener(leaveEvent, cancelPreview);
				button.addEventListener('focus', () => schedulePreviewTheme(themeId));
				button.addEventListener('blur', cancelPreview);
				button.addEventListener('click', event => {
					clearPreviewHover();
					clearPreviewReset();
					applyTheme(themeId);
					if (event && event.detail && event.detail > 0) {
						button.blur();
					}
				});
			});

			if (window.matchMedia) {
				systemThemeQuery = window.matchMedia('(prefers-color-scheme: dark)');
				const handleSystemThemeChange = () => {
					if (activePreference === 'auto') {
						applyTheme('auto', { persist: false, syncSelect: true });
					}
				};
				if (systemThemeQuery.addEventListener) {
					systemThemeQuery.addEventListener('change', handleSystemThemeChange);
				} else if (systemThemeQuery.addListener) {
					systemThemeQuery.addListener(handleSystemThemeChange);
				}
			}

			updateModeToggle(themeTarget.dataset.themePreference || 'auto');
			updateActivePreview(themeTarget.dataset.themePreference || 'auto');
		});
	})();
</script>
